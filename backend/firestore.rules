rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User Profiles - each user can only read/write their own profile
    match /userProfiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Health Details - each user can only read/write their own health details
    match /healthDetails/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Medications - collections with userId field
    match /medications/{medicationId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Dose History - collections with userId field
    match /doseHistory/{doseId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Users can only read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Refills owned by user
      match /refills/{refillId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Reminders owned by user
      match /reminders/{reminderId} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Deny access to all other documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
